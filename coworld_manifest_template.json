{
  "$schema": "https://raw.githubusercontent.com/Metta-AI/coworld/main/src/coworld/coworld_manifest_schema.json",
  "game": {
    "name": "tribal_village",
    "description": "A 48-agent Tribal Village Coworld where each player controls one village agent gathering, crafting, fighting tumors, and supporting its team.",
    "owner": "info@metta.ai",
    "runnable": {
      "type": "game",
      "image": "{{TRIBAL_VILLAGE_IMAGE}}",
      "run": ["python", "-m", "tribal_village_env.coworld.server"],
      "source_url": "https://github.com/Metta-AI/coworld-tribal-village/tree/main"
    },
    "config_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "additionalProperties": false,
      "required": ["tokens", "players", "max_steps", "tick_rate"],
      "properties": {
        "tokens": {
          "description": "One connection token per Tribal Village agent slot.",
          "type": "array",
          "minItems": 48,
          "maxItems": 48,
          "items": {"type": "string", "minLength": 1}
        },
        "players": {
          "description": "One player display-name object per agent slot.",
          "type": "array",
          "minItems": 48,
          "maxItems": 48,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name"],
            "properties": {
              "name": {"type": "string", "minLength": 1}
            }
          }
        },
        "max_steps": {
          "description": "Maximum simulation steps before truncation.",
          "type": "integer",
          "minimum": 1,
          "maximum": 10000
        },
        "tick_rate": {
          "description": "Simulation steps per second.",
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 60
        },
        "player_connect_timeout_seconds": {
          "description": "Seconds to wait for players before starting with no-op actions for missing slots.",
          "type": "number",
          "minimum": 0,
          "default": 180
        },
        "seed": {
          "description": "Optional deterministic episode seed used for map generation, replay, and bundled scripted AI mirrors. Omit or set 0 to choose a fresh random episode seed.",
          "type": "integer",
          "minimum": 0,
          "maximum": 2147483647
        }
      }
    },
    "results_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "additionalProperties": false,
      "required": ["scores", "team_scores", "ticks", "truncation_reason"],
      "properties": {
        "scores": {
          "description": "One cumulative reward score per agent slot.",
          "type": "array",
          "minItems": 48,
          "maxItems": 48,
          "items": {"type": "number"}
        },
        "team_scores": {
          "description": "Eight team scores, each summing the six agent scores for that village.",
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": {"type": "number"}
        },
        "ticks": {
          "type": "integer",
          "minimum": 0
        },
        "truncation_reason": {
          "type": "string"
        }
      }
    },
    "protocols": {
      "player": {
        "type": "uri",
        "value": "https://github.com/Metta-AI/coworld-tribal-village/blob/main/tribal_village_env/coworld/docs/player_protocol_spec.md"
      },
      "global": {
        "type": "uri",
        "value": "https://github.com/Metta-AI/coworld-tribal-village/blob/main/tribal_village_env/coworld/docs/global_protocol_spec.md"
      }
    },
    "docs": {
      "readme": {
        "type": "uri",
        "value": "https://github.com/Metta-AI/coworld-tribal-village/blob/main/README.md"
      },
      "pages": [
        {
          "id": "rules.md",
          "title": "rules.md",
          "content": {
            "type": "uri",
            "value": "https://github.com/Metta-AI/coworld-tribal-village/blob/main/docs/rules.md"
          }
        },
        {
          "id": "play_tribal_village.md",
          "title": "play_tribal_village.md",
          "content": {
            "type": "uri",
            "value": "https://github.com/Metta-AI/coworld-tribal-village/blob/main/docs/play_tribal_village.md"
          }
        }
      ]
    }
  },
  "player": [
    {
      "id": "default-ai-agent",
      "name": "Default Scripted AI",
      "type": "player",
      "image": "{{TRIBAL_VILLAGE_IMAGE}}",
      "run": ["python", "-m", "tribal_village_env.coworld.player"],
      "source_url": "https://github.com/Metta-AI/coworld-tribal-village/blob/main/tribal_village_env/coworld/player.py",
      "description": "Bundled player that runs the existing Nim role-based scripted AI through the Coworld player WebSocket."
    }
  ],
  "reporter": [],
  "commissioner": [
